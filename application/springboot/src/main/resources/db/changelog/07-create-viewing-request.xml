<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="7-create-viewing-request" author="opoiasnik">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="viewing_request"/></not>
        </preConditions>
        <createTable tableName="viewing_request">
            <column name="viewing_request_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="requested_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="note" type="VARCHAR(1000)"/>
            <column name="requester_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_viewing_request_requester" references="users(user_id)"/>
            </column>
            <column name="owner_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_viewing_request_owner" references="users(user_id)"/>
            </column>
            <column name="listing_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_viewing_request_listing" references="listing(listing_id)"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>

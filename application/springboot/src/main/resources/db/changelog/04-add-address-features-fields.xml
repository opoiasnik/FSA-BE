<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="4-address-district" author="opoiasnik">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="listing" columnName="address_district"/></not>
        </preConditions>
        <addColumn tableName="listing">
            <column name="address_district" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="4-address-region" author="opoiasnik">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="listing" columnName="address_region"/></not>
        </preConditions>
        <addColumn tableName="listing">
            <column name="address_region" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="4-address-lat" author="opoiasnik">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="listing" columnName="address_lat"/></not>
        </preConditions>
        <addColumn tableName="listing">
            <column name="address_lat" type="DECIMAL(10,7)"/>
        </addColumn>
    </changeSet>

    <changeSet id="4-address-lng" author="opoiasnik">
        <preConditions onFail="MARK_RAN">

        </addColumn>
    </changeSet>

    <changeSet id="4-features-elevator" author="opoiasnik">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="listing" columnName="features_elevator"/></not>
        </preConditions>
        <addColumn tableName="listing">
            <column name="features_elevator" type="BOOLEAN"/>
        </addColumn>
    </changeSet>

    <changeSet id="4-features-pets-allowed" author="opoiasnik">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="listing" columnName="features_pets_allowed"/></not>
        </preConditions>

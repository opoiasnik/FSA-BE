        </addColumn>
    </changeSet>

    <changeSet id="4-features-year-built" author="opoiasnik">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="listing" columnName="features_year_built"/></not>
        </preConditions>
        <addColumn tableName="listing">
            <column name="features_year_built" type="INT"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
